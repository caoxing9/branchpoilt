{
  "$schema": "https://raw.githubusercontent.com/nickel-org/nickel.rs/master/examples/example.schema.json",
  "productName": "BranchPilot",
  "version": "0.1.0",
  "identifier": "com.branchpilot.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "BranchPilot",
        "width": 420,
        "height": 600,
        "resizable": true,
        "decorations": true,
        "minWidth": 360,
        "minHeight": 400,
        "visible": true,
        "skipTaskbar": false,
        "alwaysOnTop": false,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self' ipc: http://ipc.localhost; script-src 'self' 'unsafe-inline' 'unsafe-eval'; style-src 'self' 'unsafe-inline'; connect-src ipc: http://ipc.localhost; frame-src http://localhost:*;"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.png"
    ]
  }
}
